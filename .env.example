# Base de datos Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# Frontend (Vite) — solo necesario si usás Supabase realtime en el cliente
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API
VITE_API_URL=/api

# Server
PORT=80
NODE_ENV=production

# Autenticación (contraseña única). Si DASHBOARD_PASSWORD está vacía, la auth queda deshabilitada.
DASHBOARD_PASSWORD=
JWT_SECRET=

# Notificaciones Telegram (opcional). Si faltan, no se envían notificaciones.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
